{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": ["baseline.config.json"],
  "jsPlugins": [{ "name": "import-js", "specifier": "eslint-plugin-import" }],
  "ignorePatterns": [".pnpm-store/**", ".idea/**", "out/**", "node_modules/**", "*.config.js"],
  "env": {
    "node": true
  },
  "plugins": ["typescript", "node", "oxc", "import", "unicorn"],
  "categories": {
    "correctness": "error", // Code that is definitely wrong or useless
    "perf": "error", // Rules that aim to improve runtime performance
    "suspicious": "error", // Code that is likely to be wrong or useless,
    "nursery": "error", // Rules that ban specific patterns or features,
    "pedantic": "off", // Extra strict rules that may have false positives
    "restriction": "off", // Rules under development that may change
    "style": "off" // Idiomatic and consistent style rules
  },
  "rules": {
    // Additional
    "import-js/order": [
      "error",
      {
        "groups": ["builtin", "external", "internal", ["parent", "sibling", "index"]],
        "pathGroups": [
          {
            "pattern": "@/**",
            "group": "internal",
            "position": "before"
          },
          {
            "pattern": "@tests/**",
            "group": "internal",
            "position": "after"
          }
        ],
        "pathGroupsExcludedImportTypes": ["builtin"],
        "newlines-between": "always",
        "alphabetize": {
          "order": "asc",
          "caseInsensitive": true
        }
      }
    ],
    "import/no-relative-parent-imports": "error",
    "eslint/no-console": "error"
  },
  "overrides": [
    {
      "files": ["scripts/check-l10n.js", "esbuild.js"],
      "rules": {
        "eslint/no-console": "allow"
      }
    },
    {
      "files": [".vscode-test.mjs"],
      "rules": {
        "import/named": "off"
      }
    },
    {
      "files": ["src/webview/**/*.ts"],
      "env": {
        "node": false,
        "browser": true
      }
    }
  ]
}
