{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [".pnpm-store/**", ".idea/**", "out/**", "node_modules/**", "*.config.js"],
  "env": {
    "node": true
  },
  "plugins": ["typescript", "node", "oxc", "import", "unicorn"],
  "categories": {
    "correctness": "error", // Code that is definitely wrong or useless
    "suspicious": "warn", // Code that is likely to be wrong or useless,
    "pedantic": "off", // Extra strict rules that may have false positives
    "perf": "off", // Rules that aim to improve runtime performance
    "style": "off", // Idiomatic and consistent style rules
    "nursery": "off", // Rules that ban specific patterns or features,
    "restriction": "off" // Rules under development that may change
  },
  "rules": {
    // Additional
    "no-relative-parent-imports": "warn",

    // suspicious
    "no-shadow": "off",
    "no-named-as-default": "off",
    "require-post-message-target-origin": "off",
    "no-array-sort": "off"
  },
  "overrides": [
    {
      "files": ["src/webview/**/*.ts"],
      "env": {
        "node": false,
        "browser": true
      }
    }
  ]
}
