{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "lib": ["es2020", "dom"],
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "include": [
    "./extension/**/*.ts",
    "./features/**/*.ts",
    "../src/features/**/*.ts",
    "./webview/**/*.ts",
    "../web/**/*.ts"
  ]
}
